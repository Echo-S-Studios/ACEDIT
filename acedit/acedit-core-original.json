  "conversionRules": {
    "uppercaseOffset": {
      "description": "Offset from base codepoint for uppercase letters",
      "formula": "baseCodepoint + (charCode - 65)",
      "range": "A-Z (65-90)"
    },
    "lowercaseOffset": {
      "description": "Offset from base codepoint for lowercase letters",
      "formula": "baseCodepoint + (charCode - 97)",
      "range": "a-z (97-122)"
    },
    "digitOffset": {
      "description": "Offset from base codepoint for digits",
      "formula": "baseCodepoint + (charCode - 48)",
      "range": "0-9 (48-57)"
    },
    "exceptions": {
      "UMBRAL": ["C", "H", "I", "R", "Z"],
      "ULTRA": ["C", "H", "N", "P", "Q", "R", "Z"]
    }
  },
  "usage": {
    "description": "ACEDIT typographic firmware for register-based text transformation",
    "implementation": "Map ASCII characters to Unicode mathematical alphanumeric symbols",
    "registers": "6 distinct typographic registers with semantic domains",
    "operators": "18 mathematical operators for structured notation",
    "modifiers": "6 combining diacritical marks for semantic annotation",
    "notes": [
      "Each register has a distinct Unicode block and semantic meaning",
      "UMBRAL and ULTRA have special character exceptions",
      "GREY, UMBRAL, and UCF use alternative digit representations",
      "Punctuation is mapped to geometric/mathematical alternatives",
      "Combining modifiers can be applied to any character for annotation"
    ]
  }
